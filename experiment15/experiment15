Experiment 15:  
Write a shell script to print the first n Fibonacci numbers.

fibonacci.sh
#!/bin/bash
read -p "Enter number of terms: " n
a=0
b=1
echo "Fibonacci Series:"
for (( i=1; i<=n; i++ ))
do
    echo -n "$a "
    temp=$((a + b))
    a=$b
    b=$temp
done
echo

